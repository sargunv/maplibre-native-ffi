PROJECT_NAME = "MapLibre Native C API"
PROJECT_BRIEF = "Public C ABI for the MapLibre Native wrapper."

OUTPUT_DIRECTORY = public/api/c
HTML_OUTPUT = .
INPUT = ../include
FILE_PATTERNS = *.h
RECURSIVE = YES

GENERATE_HTML = YES
GENERATE_LATEX = NO
GENERATE_XML = NO

EXTRACT_ALL = NO
EXTRACT_STATIC = NO
HIDE_UNDOC_MEMBERS = YES
HIDE_UNDOC_CLASSES = YES

OPTIMIZE_OUTPUT_FOR_C = YES
TYPEDEF_HIDES_STRUCT = YES
MACRO_EXPANSION = YES
EXPAND_ONLY_PREDEF = YES
PREDEFINED = MLN_API= \
             MLN_NOEXCEPT=

SHOW_INCLUDE_FILES = NO
SOURCE_BROWSER = YES
INLINE_SOURCES = NO
REFERENCED_BY_RELATION = NO
REFERENCES_RELATION = NO
GENERATE_TREEVIEW = YES
FULL_SIDEBAR = NO
DISABLE_INDEX = NO
LAYOUT_FILE = api/c/DoxygenLayout.xml

WARN_AS_ERROR = NO
WARN_IF_UNDOCUMENTED = NO
WARN_IF_DOC_ERROR = YES
